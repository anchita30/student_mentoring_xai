# ============================================
# DomainDNA Student Analytics - .gitignore
# ============================================

# ====================
# Python
# ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/
backend/venv/

# Byte-compiled files
*.pyc
*.pyo

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# ====================
# Node.js / Frontend
# ====================
node_modules/
frontend/node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
frontend/.next/
out/
frontend/out/

# Production builds
build/
frontend/build/

# ====================
# Environment Files
# ====================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local

# ====================
# IDE / Editor
# ====================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ====================
# OS Generated
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ====================
# Logs & Debug
# ====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# ====================
# Testing & Coverage
# ====================
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ====================
# Docker
# ====================
*.log
docker-compose.override.yml

# ====================
# TypeScript
# ====================
*.tsbuildinfo
next-env.d.ts

# ====================
# Misc
# ====================
*.pem
.vercel
.turbo

